rules_version = '2';

// ============================================================
// OPENY OS – Firestore Security Rules
// ============================================================
// WARNING: These rules grant open read/write access to all
// collections because the app currently has no authentication.
//
// ACTION REQUIRED before going to production:
//   1. Add Firebase Authentication to the app.
//   2. Replace `allow read, write: if true;` with rules that
//      verify `request.auth != null` and validate data fields.
//   3. Run `firebase deploy --only firestore:rules` to deploy.
//
// All business data lives under:
//   workspaces/{workspaceId}/{collection}/{docId}
//
// System collections (mail, fcmTokens) remain at root level
// because they are managed by Firebase extensions.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Workspace-scoped business data ───────────────────────
    // All OPENY OS data is stored under workspaces/{workspaceId}
    // so it is device-agnostic and workspace-scoped.

    match /workspaces/{workspaceId} {
      allow read, write: if true;

      match /clients/{docId} {
        allow read, write: if true;
      }

      match /tasks/{docId} {
        allow read, write: if true;
      }

      match /team/{docId} {
        allow read, write: if true;
      }

      match /activities/{docId} {
        allow read, write: if true;
      }

      match /contentItems/{docId} {
        allow read, write: if true;
      }

      match /approvals/{docId} {
        allow read, write: if true;
      }

      match /assets/{docId} {
        allow read, write: if true;
      }

      match /clientNotes/{docId} {
        allow read, write: if true;
      }

      match /bankEntries/{docId} {
        allow read, write: if true;
      }

      match /notifications/{docId} {
        allow read, write: if true;
      }

      match /invitations/{docId} {
        allow read, write: if true;
      }

      match /publishingEvents/{docId} {
        allow read, write: if true;
      }

      match /publishingFailures/{docId} {
        allow read, write: if true;
      }

      match /userNotificationPreferences/{docId} {
        allow read, write: if true;
      }

      match /recurringTaskTemplates/{docId} {
        allow read, write: if true;
      }

      match /userPreferences/{docId} {
        // Users can only read and write their own preferences document
        // (the document ID is the Firebase Auth UID).
        allow read, write: if request.auth != null && request.auth.uid == docId;
      }
    }

    // ── Firebase Trigger Email extension ────────────────────
    // Stays at root level – required by the extension.
    match /mail/{docId} {
      allow read, write: if true;
    }

    // ── FCM push tokens ──────────────────────────────────────
    // Stays at root level – shared across workspaces.
    match /fcmTokens/{docId} {
      allow read, write: if true;
    }
  }
}
