# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Auth — used by middleware and API routes for session validation.
# Make sure Supabase Auth (Email/Password provider) is enabled in the
# Supabase dashboard: Authentication → Providers → Email.
# Run supabase-migration-users-roles.sql once in the SQL Editor to create
# the users table and the auto-create trigger.

# Cloudflare R2 — sole file storage provider
#
# Setup steps:
#   1. Go to https://dash.cloudflare.com/ → R2 → Create bucket
#   2. Create an API token with Object Read & Write permissions on that bucket
#   3. Enable public access (or set up a custom domain) and copy the public URL
#   4. Configure CORS on the bucket to allow browser PUT uploads.
#      Go to R2 → your bucket → Settings → CORS and add a rule:
#
#        AllowedOrigins: ["*"]            (or your app domain, e.g. https://app.example.com)
#        AllowedMethods: ["GET", "PUT", "HEAD", "DELETE"]
#        AllowedHeaders: ["*"]            (must allow Content-Type and other upload headers)
#        ExposeHeaders:  ["ETag"]         ← REQUIRED for multipart (large file) uploads
#        MaxAgeSeconds:  3600
#
#      Without ExposeHeaders: ["ETag"], large files (> 50 MB) will always fail because
#      the browser cannot read the ETag from R2's response to assemble multipart parts.
#      Without AllowedHeaders: ["*"], the PUT request may be rejected with a CORS error
#      that appears to the browser as a generic network failure (not a 4xx response).
#
#      Via wrangler.toml:
#        [[r2_buckets]]
#        binding = "BUCKET"
#        bucket_name = "client-assets"
#        cors_rules = [{ allowed_origins = ["*"], allowed_methods = ["GET","PUT","HEAD","DELETE"], allowed_headers = ["*"], expose_headers = ["ETag"], max_age_seconds = 3600 }]
#
#   5. Fill in the values below
#
# R2_PUBLIC_URL must NOT have a trailing slash.
# Example values:
#   R2_PUBLIC_URL=https://assets.yourdomain.com      (custom domain)
#   R2_PUBLIC_URL=https://pub-abc123.r2.dev           (Cloudflare-hosted public URL)

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=client-assets
R2_PUBLIC_URL=

# Reminders cron secret — protects GET /api/reminders/cron
# Pass as the "x-cron-secret" header or "secret" query param.
CRON_SECRET=

# Email (Resend) — used for transactional emails (task assignments, approvals, publishing)
# Get a key from https://resend.com
RESEND_API_KEY=
EMAIL_FROM=OPENY OS <noreply@openy-os.com>

# App URL — used in email links (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# AI (Gemini) — for AI writing features
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
