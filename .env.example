NEXT_PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Drive — OAuth 2.0 auth (server-side only — never expose to the browser)
#
# Setup steps:
#   1. Go to https://console.cloud.google.com/ → APIs & Services → Credentials
#   2. Create an OAuth 2.0 Client ID (Web application type)
#   3. Enable the Google Drive API in your project
#   4. Use the OAuth Playground or your app's auth flow to obtain a refresh token
#      with the https://www.googleapis.com/auth/drive scope
#   5. Fill in the values below

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Admin Google account email — used to verify the Drive connection is the correct account
# Defaults to thetaiseer@gmail.com if not set
GOOGLE_ADMIN_EMAIL=thetaiseer@gmail.com

# Root Drive folder — can be a bare folder ID or a full Drive URL
GOOGLE_DRIVE_FOLDER_ID=

# Sync secret — optional but recommended.
# Set to a random string to protect the scheduled sync endpoint
# (GET /api/assets/sync/cron) from unauthenticated callers.
# Pass as the "x-sync-secret" request header or "secret" query param.
SYNC_SECRET=
