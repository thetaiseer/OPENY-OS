# Storage provider — controls which storage backend is active.
# Defaults to 'google-drive' when not set.
# Future values: onedrive, s3, local
STORAGE_PROVIDER=google-drive

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Auth — used by middleware and API routes for session validation.
# Make sure Supabase Auth (Email/Password provider) is enabled in the
# Supabase dashboard: Authentication → Providers → Email.
# Run supabase-migration-users-roles.sql once in the SQL Editor to create
# the users table and the auto-create trigger.
# Google Drive — OAuth 2.0 auth (server-side only — never expose to the browser)
#
# Setup steps:
#   1. Go to https://console.cloud.google.com/ → APIs & Services → Credentials
#   2. Create an OAuth 2.0 Client ID (Web application type)
#   3. Enable the Google Drive API in your project
#   4. Use the OAuth Playground or your app's auth flow to obtain a refresh token
#      with the https://www.googleapis.com/auth/drive scope
#   5. Fill in the values below

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Admin Google account email — used to verify the Drive connection is the correct account
# Defaults to thetaiseer@gmail.com if not set
GOOGLE_ADMIN_EMAIL=thetaiseer@gmail.com

# Root Drive folder — can be a bare folder ID or a full Drive URL
GOOGLE_DRIVE_FOLDER_ID=

# Sync secret — optional but recommended.
# Set to a random string to protect the scheduled sync endpoint
# (GET /api/assets/sync/cron) from unauthenticated callers.
# Pass as the "x-sync-secret" request header or "secret" query param.
SYNC_SECRET=

# Email (Resend) — used for transactional emails (task assignments, approvals, publishing)
# Get a key from https://resend.com
RESEND_API_KEY=
EMAIL_FROM=OPENY OS <notifications@openy.app>

# App URL — used in email links (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# AI (Gemini) — for AI writing features
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
