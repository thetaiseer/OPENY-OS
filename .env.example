NEXT_PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Drive — OAuth 2.0 user-based auth (server-side only — never expose to the browser)
#
# Setup steps:
#   1. Go to https://console.cloud.google.com/ → APIs & Services → Credentials
#   2. Create an OAuth 2.0 Client ID (Application type: Web application)
#   3. Add your callback URL to "Authorized redirect URIs":
#        http://localhost:3000/api/auth/google/callback  (local dev)
#        https://yourdomain.com/api/auth/google/callback  (production)
#   4. Fill in GOOGLE_OAUTH_CLIENT_ID and GOOGLE_OAUTH_CLIENT_SECRET below
#   5. Set GOOGLE_OAUTH_REDIRECT_URI to the matching callback URL
#   6. Enable the Google Drive API and Google OAuth2 API in your project
#   7. Visit /api/auth/google in your browser and complete the consent screen
#   8. Copy the refresh token shown and paste it into GOOGLE_OAUTH_REFRESH_TOKEN
#   9. Restart the server — uploads will now be owned by your Google account

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_OAUTH_REFRESH_TOKEN=

# Root Drive folder — can be a bare folder ID or a full Drive URL
GOOGLE_DRIVE_FOLDER_ID=
