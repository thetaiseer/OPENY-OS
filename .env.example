NEXT_PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Drive — Service Account auth (server-side only — never expose to the browser)
#
# Setup steps:
#   1. Go to https://console.cloud.google.com/ → IAM & Admin → Service Accounts
#   2. Create a new Service Account and download a JSON key
#   3. Enable the Google Drive API in your project
#   4. Share the root Drive folder with the service account email (Editor access)
#   5. Fill in GOOGLE_DRIVE_CLIENT_EMAIL and GOOGLE_DRIVE_PRIVATE_KEY below
#      (paste the private_key value from the JSON file; keep \n escape sequences)
#   6. Set GOOGLE_DRIVE_FOLDER_ID to the root folder ID or full Drive folder URL

GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=

# Admin Google account email — used to verify the Drive connection is the correct account
# Defaults to thetaiseer@gmail.com if not set
GOOGLE_ADMIN_EMAIL=thetaiseer@gmail.com

# Root Drive folder — can be a bare folder ID or a full Drive URL
GOOGLE_DRIVE_FOLDER_ID=
