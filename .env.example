# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=client-assets
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Auth — used by middleware and API routes for session validation.
# Make sure Supabase Auth (Email/Password provider) is enabled in the
# Supabase dashboard: Authentication → Providers → Email.
# Run supabase-migration-users-roles.sql once in the SQL Editor to create
# the users table and the auto-create trigger.
#
# Owner identity (for owner-only OPENY DOCS access control)
NEXT_PUBLIC_OWNER_EMAIL=thetaiseer@gmail.com

# Cloudflare R2 — sole file storage provider
#
# Setup steps:
#   1. Go to https://dash.cloudflare.com/ → R2 → Create bucket
#   2. Create an API token with Object Read & Write permissions on that bucket
#   3. Enable a custom domain (or use the r2.dev public URL) for the bucket
#      so files are accessible at ${R2_PUBLIC_URL}/{fileKey}
#   4. Configure CORS on the bucket to allow GET requests from your app domain.
#      Go to R2 → your bucket → Settings → CORS and add a rule:
#
#        AllowedOrigins: ["*"]            (or your app domain)
#        AllowedMethods: ["GET", "HEAD"]
#        AllowedHeaders: ["*"]
#        MaxAgeSeconds:  3600
#
#      Note: Uploads go through the Next.js server (server-side to R2), so
#      browser PUT access is not required.  Only GET/HEAD for serving files.
#
#   5. Fill in the values below
#
# R2_PUBLIC_URL must NOT have a trailing slash.
# Example values:
#   R2_PUBLIC_URL=https://files.openy-os.com  (custom domain, recommended)
#   R2_PUBLIC_URL=https://pub-abc123.r2.dev    (Cloudflare-hosted public URL)

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=client-assets
R2_PUBLIC_URL=

# Uploads (all bytes go to R2 via Next.js API — assets, tasks, docs exports, previews)
# ---------------------------------------------------------------------------
# UPLOAD_RATE_LIMIT_PER_HOUR — presign + multipart-init per user per hour (0 = off). Default 10000.
# UPLOAD_MAX_FILE_SIZE_GB — optional hard cap in GB (0 = unlimited). Large files use multipart.
# UPLOAD_MULTIPART_THRESHOLD_MB — above this size, use multipart (default 4). Mirror in browser:
# NEXT_PUBLIC_UPLOAD_MULTIPART_THRESHOLD_MB=4
# UPLOAD_RATE_LIMIT_PER_HOUR=0
# UPLOAD_MAX_FILE_SIZE_GB=0

# Reminders cron secret — protects GET /api/reminders/cron
# Pass as the "x-cron-secret" header or "secret" query param.
CRON_SECRET=

# Email (Resend) — used for transactional emails (team invites, tasks, publishing, …)
# Create an API key at https://resend.com and add the domain you send from.
RESEND_API_KEY=
# From address must use a domain verified in Resend (e.g. onboarding@resend.dev for tests).
RESEND_FROM_EMAIL=OPENY OS <onboarding@resend.dev>
# Legacy alias read by some routes:
INVITE_FROM_EMAIL=
EMAIL_FROM=OPENY OS <noreply@openy-os.com>

# App URL — used in invitation emails and invite links (no trailing slash). Required for team invites.
NEXT_PUBLIC_APP_URL=https://your-domain.com

# AI (Gemini) — for AI writing features
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
